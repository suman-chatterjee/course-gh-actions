<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product Id="*" Name="PortalServices" Language="1033" Version="1.0.0.0" Manufacturer="Course GH Actions" UpgradeCode="7e8c0132-16f5-4ac5-9f0d-9a1d4890b2a1">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="PortalServices" />
      </Directory>
    </Directory>

    <Feature Id="ProductFeature" Title="PortalServices" Level="1">
      <ComponentGroupRef Id="PortalServicesComponents" />
      <ComponentGroupRef Id="ServiceComponentGroup" />
    </Feature>

    <!-- Install/Start Service -->
    <InstallExecuteSequence>
      <ScheduleReboot After="InstallFinalize" />
    </InstallExecuteSequence>
  </Product>

  <!-- Fragment for Service Component -->
  <Fragment>
    <ComponentGroup Id="ServiceComponentGroup">
      <Component Id="PortalServicesServiceComponent" Directory="INSTALLFOLDER" Guid="*">
        <!-- Service Installation -->
        <File Id="PortalServicesExe" Source="$(var.PublishDir)\PortalServices.exe" KeyPath="yes" />
        
        <!-- Register Windows Service -->
        <ServiceInstall Id="ServiceInstaller"
                        Type="ownProcess"
                        Name="PortalServices"
                        DisplayName="Portal Services"
                        Description="ASP.NET Core Portal Services Application"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal" />

        <!-- Configure service failure recovery -->
        <util:ServiceConfig
                            ServiceName="PortalServices"
                            FirstFailureActionType="restart"
                            SecondFailureActionType="restart"
                            ThirdFailureActionType="none"
                            RestartServiceDelayInSeconds="60" />
        
        <!-- Control Service (Start on install, Stop on uninstall) -->
        <ServiceControl Id="ServiceControl"
                        Name="PortalServices"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
